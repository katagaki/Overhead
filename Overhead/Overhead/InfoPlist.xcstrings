    "NSLocationAlwaysAndWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location Always and When In Use Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Overhead uses your location in the background to keep the Live Activity updated with your current position even when the app is not open."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Overheadはアプリを開いていないときでもライブアクティビティを最新の位置情報で更新するため、バックグラウンドで位置情報を使用します。"
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location When In Use Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Overhead uses your location to track your position along the train line and show it on the Live Activity."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Overheadは路線上の現在位置を追跡し、ライブアクティビティに表示するために位置情報を使用します。"
          }
        }
      }
    }
  },
  "version" : "1.2"
